# KeyRelay Configuration
# AGENT_VAULT_KEY=<generated-fernet-key>
# REQUIRE_AGENT_AUTH=true
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
# AGENT_VAULT_MAX_AUDIT_ROWS=100000

